{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/cli.ts",
    "src/utils/command.ts",
    "src/utils/streaming-json.ts",
    "src/utils/output.ts",
    "src/utils/binary.ts",
    "src/utils/graph-analysis.ts"
  ],
  "out": "docs/html",
  "name": "jref - JSON Reference Tool",
  "includeVersion": true,
  "excludeInternal": true,
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "cleanOutputDir": true,
  "readme": "README.md"
}
