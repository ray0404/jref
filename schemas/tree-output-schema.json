{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///data/data/com.termux/files/home/Projects/CLI_jref/tree-output-schema.json",
  "title": "Project Snapshot Schema",
  "type": "array",
  "items": {
    "oneOf": [
      { "$ref": "#/$defs/node" },
      { "$ref": "#/$defs/report" }
    ]
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "enum": ["file", "directory"] },
        "contents": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "file" } } },
          "then": {
            "not": { "required": ["contents"] },
            "description": "Files must not have a contents property."
          }
        }
      ]
    },
    "report": {
      "type": "object",
      "required": ["type", "directories", "files"],
      "properties": {
        "type": { "const": "report" },
        "directories": { "type": "integer", "minimum": 0 },
        "files": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
